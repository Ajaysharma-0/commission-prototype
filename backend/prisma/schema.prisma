generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

enum HotelStatus {
  ACTIVE
  INACTIVE
}

enum CommissionBase {
  SAFETY_NET
  OWNER_NET_REVENUE
  TRAVACOT_REVENUE
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum CommissionStatus {
  PENDING
  PAID
}

model Partner {
  id              String   @id @default(uuid())
  name            String
  status          PartnerStatus @default(ACTIVE)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  hotels                  Hotel[]
  customerSlots           CustomerPartnerSlot[]
  bookingCommissions      BookingPartnerCommission[]
  commissionHistory       PartnerCommissionHistory[]
  wallet                  PartnerWallet?
  walletTransactions      PartnerWalletTransaction[]

  @@map("partners")
}

model Hotel {
  id        String      @id @default(uuid())
  name      String
  price     Decimal     @db.Decimal(10, 2)
  partnerId String?     @map("partner_id")
  status    HotelStatus @default(ACTIVE)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  partner            Partner?                   @relation(fields: [partnerId], references: [id])
  bookings           Booking[]
  commissionHistory  PartnerCommissionHistory[]

  @@map("hotels")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookings           Booking[]
  partnerSlots       CustomerPartnerSlot[]
  partnerCommissions BookingPartnerCommission[]
  commissionHistory  PartnerCommissionHistory[]

  @@map("customers")
}

model Booking {
  id            String   @id @default(uuid())
  customerId    String   @map("customer_id")
  hotelId       String   @map("hotel_id")
  bookingAmount Decimal  @map("booking_amount") @db.Decimal(10, 2)
  bookingDate   DateTime @default(now()) @map("booking_date")
  createdAt     DateTime @default(now()) @map("created_at")

  customer           Customer                   @relation(fields: [customerId], references: [id])
  hotel              Hotel                      @relation(fields: [hotelId], references: [id])
  revenue            BookingRevenue?
  partnerCommissions BookingPartnerCommission[]
  walletTransactions PartnerWalletTransaction[]
  commissionHistory  PartnerCommissionHistory[]

  @@map("bookings")
}

model CommissionConfiguration {
  id                       String         @id @default(uuid())
  travacotPercentage       Decimal        @map("travacot_percentage") @db.Decimal(5, 2)
  transactionFeePercentage Decimal        @map("transaction_fee_percentage") @db.Decimal(5, 2)
  safetyNetPercentage      Decimal        @map("safety_net_percentage") @db.Decimal(5, 2)
  slot1CommissionPercentage Decimal       @default(7.5) @map("slot1_commission_percentage") @db.Decimal(5, 2)
  slot2CommissionPercentage Decimal       @default(5) @map("slot2_commission_percentage") @db.Decimal(5, 2)
  slot3CommissionPercentage Decimal       @default(2.5) @map("slot3_commission_percentage") @db.Decimal(5, 2)
  commissionBase           CommissionBase @default(SAFETY_NET) @map("commission_base")
  active                   Boolean        @default(true)
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")

  @@map("commission_configuration")
}

model CustomerPartnerSlot {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  slotNumber Int      @map("slot_number")
  partnerId  String   @map("partner_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  customer Customer @relation(fields: [customerId], references: [id])
  partner  Partner  @relation(fields: [partnerId], references: [id])

  @@unique([customerId, slotNumber])
  @@unique([customerId, partnerId])
  @@map("customer_partner_slots")
}

model BookingRevenue {
  id               String  @id @default(uuid())
  bookingId        String  @unique @map("booking_id")
  bookingAmount    Decimal @map("booking_amount") @db.Decimal(10, 2)
  travacotRevenue  Decimal @map("travacot_revenue") @db.Decimal(10, 2)
  transactionFee   Decimal @map("transaction_fee") @db.Decimal(10, 2)
  ownerNetRevenue  Decimal @map("owner_net_revenue") @db.Decimal(10, 2)
  safetyNet        Decimal @map("safety_net") @db.Decimal(10, 2)

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("booking_revenue")
}

model BookingPartnerCommission {
  id               String           @id @default(uuid())
  bookingId        String           @map("booking_id")
  customerId       String           @map("customer_id")
  partnerId        String           @map("partner_id")
  slotNumber       Int              @map("slot_number")
  commissionRate   Decimal          @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal          @map("commission_amount") @db.Decimal(10, 2)
  status           CommissionStatus @default(PAID)

  booking  Booking  @relation(fields: [bookingId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  partner  Partner  @relation(fields: [partnerId], references: [id])

  @@map("booking_partner_commissions")
}

model PartnerWallet {
  id               String  @id @default(uuid())
  partnerId        String  @unique @map("partner_id")
  totalCredit      Decimal @default(0) @map("total_credit") @db.Decimal(12, 2)
  totalDebit       Decimal @default(0) @map("total_debit") @db.Decimal(12, 2)
  availableBalance Decimal @default(0) @map("available_balance") @db.Decimal(12, 2)

  partner Partner @relation(fields: [partnerId], references: [id])

  @@map("partner_wallet")
}

model PartnerCommissionHistory {
  id             String   @id @default(uuid())
  customerId     String   @map("customer_id")
  partnerId      String   @map("partner_id")
  hotelId        String   @map("hotel_id")
  firstBookingId String   @map("first_booking_id")
  rewardedAt     DateTime @default(now()) @map("rewarded_at")

  customer     Customer @relation(fields: [customerId], references: [id])
  partner      Partner  @relation(fields: [partnerId], references: [id])
  hotel        Hotel    @relation(fields: [hotelId], references: [id])
  firstBooking Booking  @relation(fields: [firstBookingId], references: [id])

  @@unique([customerId, hotelId])
  @@map("partner_commission_history")
}

model PartnerWalletTransaction {
  id              String                @id @default(uuid())
  partnerId       String                @map("partner_id")
  bookingId       String?               @map("booking_id")
  transactionType WalletTransactionType @map("transaction_type")
  amount          Decimal               @db.Decimal(10, 2)
  remarks         String?
  createdAt       DateTime              @default(now()) @map("created_at")

  partner Partner  @relation(fields: [partnerId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@map("partner_wallet_transactions")
}
